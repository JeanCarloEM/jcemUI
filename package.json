    "fa:gen": "tsx ./scripts/generate-fontawesome.ts",
    "fa:gen:watch": "tsx ./scripts/generate-fontawesome.ts",
    "tailwind:watch": "npx tailwindcss-cli -i ./src/assets/css/tailwind.css -o ./src/__generated__/tailwind.generated.css --watch",
    "types:gen": "tsx ./scripts/generate-type-metadata.ts",
    "types:gen:watch": "tsx ./scripts/generate-type-metadata.ts --watch",
    "scss": "sass src/assets/scss:src/assets/css --no-source-map --style=compressed --watch",
    "build": "npm run agent:build",
    "build:bundle": "vite build --config vite.merged.config.ts && shx mv dist/merged/index.html dist/merged/calc.bundle.html",
    "build:importmap": "tsx ./scripts/genImportMap.ts",
    "format": "prettier --write .",
    "lint": "eslint src/assets/tsx --ext .ts,.tsx",
    "pretty": "prettier --write \"./**/*.{httml,js,jsx,tsx,mjs,cjs,ts,tsx,json,scss,css}\"",
